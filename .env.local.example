# Notion Integration Token
# Create at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Notion Database IDs (extracted from your existing databases)
NOTION_REVIEWER_DB=020a7d2e-1123-43a3-b90d-68f518c9787a
NOTION_INTAKE_DB=51f37b76-d21e-4ab3-b66e-01db93ed94bc
NOTION_SCORES_DB=1082fd70-84c7-47be-b7d0-5963ee97de7e

# JWT Secret for session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=your-random-secret-here

# Vercel Blob Storage (for profile photo uploads)
# On Vercel: auto-injected when a Blob store is connected (Settings → Storage)
# Locally: generate at https://vercel.com/dashboard/stores → Create Blob Store → Token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx

# Base URL (update for production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# PCS Database IDs (12 databases in the Nordic PCS system)
NOTION_PCS_DOCUMENTS_DB=44020402bbbc445d830c806d114e6d99
