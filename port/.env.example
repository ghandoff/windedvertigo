# Auth
AUTH_SECRET=your_auth_secret
NEXT_PUBLIC_APP_URL=https://port.windedvertigo.com
ADMIN_EMAILS=garrett@windedvertigo.com

# AI (Claude via Vercel AI Gateway)
# All port AI calls route through Vercel AI Gateway for unified observability,
# cost tracking, and provider failover. The Anthropic SDK natively respects
# ANTHROPIC_API_KEY + ANTHROPIC_BASE_URL, so no code changes are required — all
# five files that instantiate `new Anthropic()` pick these up automatically.
#
# To route through Gateway (recommended):
#   ANTHROPIC_API_KEY  = your Vercel AI Gateway key (starts with vck_)
#   ANTHROPIC_BASE_URL = https://ai-gateway.vercel.sh
#
# To fall back to Anthropic direct (rollback path):
#   ANTHROPIC_API_KEY  = your Anthropic-issued key (starts with sk-ant-)
#   ANTHROPIC_BASE_URL = (unset)
ANTHROPIC_API_KEY=vck_your_vercel_ai_gateway_api_key
ANTHROPIC_BASE_URL=https://ai-gateway.vercel.sh

# Notion
NOTION_TOKEN=your_notion_integration_token
NOTION_WEBHOOK_SECRET=your_notion_webhook_secret

# Security / Cron
CRON_SECRET=your_cron_secret
UNSUBSCRIBE_SECRET=your_unsubscribe_secret

# Cloudflare R2
CF_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=port-assets
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_FEEDBACK_WEBHOOK_URL=https://hooks.slack.com/services/your/feedback/webhook
# Slack Events API signing secret — required for /api/agent/slack/events.
# Get it from the Slack app settings: api.slack.com/apps/<app-id>/general → App Credentials.
SLACK_SIGNING_SECRET=your_slack_signing_secret
# Slack bot token for the "WV-Claw" agent app (distinct from SLACK_BOT_TOKEN,
# which the existing cron / digest integrations use). Used by the port agent
# to call Slack Web API on its own behalf (users.info, chat.postMessage DMs).
# Install the WV-Claw Slack app to your workspace and copy the Bot User OAuth
# Token from api.slack.com/apps/<app-id>/install-on-team.
SLACK_AGENT_BOT_TOKEN=xoxb-your-wv-claw-bot-token

# Agent audit — data source ID of the `agent actions` Notion database. When
# set, lib/agent/audit.ts writes a structured row per agent turn (eventId,
# user, tools, duration, status, error). Also enables Slack-retry
# idempotency: the agent queries this DB for an existing Event ID before
# re-processing a delivered event.
# When unset, audit falls back to console.log only and idempotency is disabled.
AGENT_AUDIT_DB_ID=your_agent_actions_notion_data_source_id

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_DOMAIN=windedvertigo.com
RESEND_REPLY_TO=garrett@windedvertigo.com
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret

