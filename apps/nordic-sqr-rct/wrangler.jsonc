{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wv-nordic",
  "account_id": "097c92553b268f8360b74f625f6d980a",
  "main": "worker-with-scheduled.js",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat"],
  // Keep workers_dev enabled even after custom_domain routes are added.
  // Without this explicit flag, Wrangler infers workers_dev=false whenever a
  // routes/custom_domain block is present, which breaks the *.workers.dev URL.
  "workers_dev": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    // R2 migration complete 2026-05-07: all Vercel Blob writes replaced by R2.
    { "binding": "NORDIC_ASSETS", "bucket_name": "nordic-pcs" }
  ],
  "triggers": {
    "crons": [
      "*/2 * * * *",   // process-imports + drift-sync (both; see src/lib/scheduled.js)
      "*/3 * * * *",   // retry-pending-writes (Phase B strong-consistency queue)
      "*/5 * * * *",   // process-label-imports
      "0 8 * * *",     // sweep-label-drift
      "0 7 * * *",     // nightly-reping
      "0 16 * * 1"     // weekly-digest (Mondays)
    ]
  },
  "vars": {
    "NORDIC_URL": "https://nordic.windedvertigo.com",
    "CF_WORKERS_ENV": "1"
  },

  // ── Service bindings ────────────────────────────────────────────
  // SELF lets the scheduled() handler invoke the worker's own fetch()
  // without round-tripping through the public custom domain (which CF
  // 522s on self-loops). All cron triggers route through here.
  "services": [
    { "binding": "SELF", "service": "wv-nordic" }
  ],


  // ── Custom domain (DNS cutover complete 2026-05-07) ─────────────
  // nordic.windedvertigo.com is live on CF Workers. Vercel project is
  // still running in parallel during the 48h monitoring window but no
  // longer receives the custom domain traffic.
  "routes": [
    { "pattern": "nordic.windedvertigo.com", "custom_domain": true }
  ],

  // ── Secrets (set via `wrangler secret put --name wv-nordic`) ─────
  // Core auth + integrations:
  //   JWT_SECRET               — session signing
  //   NOTION_TOKEN             — Notion API (all reads/writes)
  //   NOTION_WEBHOOK_TOKEN     — inbound Notion webhook auth
  //   CRON_SECRET              — self-request auth for scheduled crons
  //   RESEND_API_KEY           — Wave 7.3.1 magic links (Resend transactional email)
  //   (BLOB_READ_WRITE_TOKEN removed 2026-05-07 — R2 migration complete, no longer needed)
  //
  // LLM:
  //   LLM_API_KEY, LLM_MODEL, LLM_PROVIDER
  //
  // Supabase (Path-2 Postgres mirror):
  //   SUPABASE_NORDIC_URL, SUPABASE_NORDIC_SECRET_KEY, SUPABASE_NORDIC_ANON_KEY
  //
  // Slack (optional — degrades gracefully if absent):
  //   SLACK_WEBHOOK_URL        — drift-sync alerts + workflow notifications
  //   SLACK_BOT_TOKEN          — Mode B DMs in nightly-reping / weekly-digest
  //   NOTION_SLACK_USER_MAP    — JSON map Notion user ID → Slack user ID
  //   NOTION_TEAM_LEADS        — JSON array of team lead Notion user IDs
  //   SLACK_REQUESTS_CHANNEL   — #requests Slack channel ID
  //   SLACK_SAFETY_CHANNEL     — #safety Slack channel ID
  //
  // Feature flags (set as secrets, not vars, so Vercel env export carried them):
  //   PCS_READ_FROM_POSTGRES   — "1" = read from Postgres (Phase A, active)
  //   PCS_WRITE_TO_POSTGRES    — "1" = dual-write to Postgres (Phase B, active)
  //   PCS_STRONG_CONSISTENCY   — "1" = enable retry queue (Phase B, active)
  //
  // URL vars (required post-cutover — already set):
  //   NEXT_PUBLIC_SITE_URL     — "https://nordic.windedvertigo.com"
  //   NEXT_PUBLIC_APP_URL      — "https://nordic.windedvertigo.com"
  //
  // All NOTION_PCS_* database IDs (see src/lib/pcs-config.js for full list)
  //
  // AICS database IDs (set via `wrangler secret put --name wv-nordic`):
  //   NOTION_AICS_DOCUMENTS_DB   — 7d743889-e549-432b-a2fc-a58491015f6b
  //   NOTION_AICS_VERSIONS_DB    — cd39cd9b-f92e-4a08-a60d-048fb6a063ba
  //   NOTION_AICS_CLAIMS_DB      — 2571a98a-2d2c-4b05-b518-56857b57c85f
}
