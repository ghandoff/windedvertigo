{
  "buildCommand": "echo 'no build step'",
  "outputDirectory": "public",
  "ignoreCommand": "npx turbo-ignore pocket.prompts",
  "crons": [
    {
      "path": "/api/weekly-summary",
      "schedule": "0 20 * * 5"
    }
  ],
  "redirects": [
    { "source": "/", "destination": "/pwa/" }
  ],
  "rewrites": [
    { "source": "/voice/:member", "destination": "/api/voice/:member" },
    { "source": "/voice", "destination": "/api/voice" },
    { "source": "/history", "destination": "/api/history" },
    { "source": "/auth/:path*", "destination": "/api/auth" },
    { "source": "/setup", "destination": "/api/setup" },
    { "source": "/slack-dm", "destination": "/api/slack-dm" },
    { "source": "/status", "destination": "/api/status" },
    { "source": "/oauth-url", "destination": "/api/oauth-url" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
