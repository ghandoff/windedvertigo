{
  "name": "@windedvertigo/coding-verifier",
  "private": true,
  "version": "1.0.0",
  "description": "evidence verification console — adjudicate double-coded research claims (cloudflare worker + d1)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:init": "wrangler d1 execute wv-coding-verifier --remote --file=migrations/0001_init.sql",
    "db:init:local": "wrangler d1 execute wv-coding-verifier --local --file=migrations/0001_init.sql",
    "db:seed": "wrangler d1 execute wv-coding-verifier --remote --file=migrations/0002_seed_amna_at_10.sql",
    "db:seed:local": "wrangler d1 execute wv-coding-verifier --local --file=migrations/0002_seed_amna_at_10.sql"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}
