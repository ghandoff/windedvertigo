{
  "ignoreCommand": "npx turbo-ignore creaseworks",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; connect-src 'self' https://vitals.vercel-insights.com; frame-src 'none'; frame-ancestors 'none'; worker-src 'self'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/harbour/creaseworks/api/cron/sync-notion",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/harbour/creaseworks/api/cron/send-digests",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/harbour/creaseworks/api/cron/send-nudges",
      "schedule": "0 8 * * *"
    }
  ]
}
