{
  "$schema": "node_modules/wrangler/config-schema.json",

  // Worker name — matches the app slug
  "name": "wv-harbour-rubric-co-builder",

  // Entry point generated by @opennextjs/cloudflare build
  "main": "worker.ts",

  // Must be 2025-04-01+ for process.env support in Workers
  "account_id": "097c92553b268f8360b74f625f6d980a",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],

  // Static assets (.open-next/assets is where opennext puts _next/static, public/, etc.)
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  // Self-reference binding — required by opennext for internal routing
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "wv-harbour-rubric-co-builder"
    }
  ]

  // Secrets — set via `wrangler secret put` or CF dashboard:
  //   POSTGRES_URL
  //   POSTGRES_URL_NON_POOLING
  //   ANTHROPIC_API_KEY
  //
  // Build-time env (set before `npm run build`):
  //   NEXT_PUBLIC_BASE_PATH=/harbour/rubric-co-builder
}
