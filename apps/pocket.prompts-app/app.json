{
  "expo": {
    "name": "pocket.prompts",
    "slug": "pocket-prompts",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pocketprompts",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.windedvertigo.pocketprompts",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "pocket.prompts uses speech recognition to transcribe your voice commands.",
        "NSMicrophoneUsageDescription": "pocket.prompts needs microphone access to capture your voice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.windedvertigo.pocketprompts",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "pocket.prompts needs microphone access to capture your voice.",
          "speechRecognitionPermission": "pocket.prompts uses speech recognition to transcribe your voice commands."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
