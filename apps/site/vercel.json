{
        "outputDirectory": ".",
        "ignoreCommand": "npx turbo-ignore @windedvertigo/site",
        "headers": [
                    {
                                    "source": "/(.*)",
                                    "headers": [
                                                    { "key": "X-Content-Type-Options", "value": "nosniff" },
                                                    { "key": "X-Frame-Options", "value": "DENY" },
                                                    { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                                                    { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
                                    ]
                    }
        ],
        "redirects": [
                    {
                                    "source": "/what-v2",
                                    "destination": "/what/",
                                    "permanent": true
                    },
                    {
                                    "source": "/what-v2/",
                                    "destination": "/what/",
                                    "permanent": true
                    },
                    {
                                    "source": "/vertigo-vault/:path*",
                                    "destination": "/reservoir/vertigo-vault/:path*",
                                    "permanent": true
                    },
                    {
                                    "source": "/vertigo-vault",
                                    "destination": "/reservoir/vertigo-vault",
                                    "permanent": true
                    }
        ],
        "rewrites": [
                    {
                                    "source": "/reservoir/creaseworks",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks"
                    },
                    {
                                    "source": "/reservoir/creaseworks/",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks"
                    },
                    {
                                    "source": "/reservoir/creaseworks/:path*",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks/:path*"
                    },
                    {
                                    "source": "/reservoir/vertigo-vault",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/reservoir/vertigo-vault"
                    },
                    {
                                    "source": "/reservoir/vertigo-vault/",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/reservoir/vertigo-vault"
                    },
                    {
                                    "source": "/reservoir/vertigo-vault/:path*",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/reservoir/vertigo-vault/:path*"
                    },
                    {
                                    "source": "/reservoir/deep-deck",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/reservoir/deep-deck"
                    },
                    {
                                    "source": "/reservoir/deep-deck/",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/reservoir/deep-deck"
                    },
                    {
                                    "source": "/reservoir/deep-deck/:path*",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/reservoir/deep-deck/:path*"
                    },
                    {
                                    "source": "/reservoir",
                                    "destination": "https://reservoir-ghandoffs-projects.vercel.app/reservoir"
                    },
                    {
                                    "source": "/reservoir/",
                                    "destination": "https://reservoir-ghandoffs-projects.vercel.app/reservoir"
                    },
                    {
                                    "source": "/reservoir/:path*",
                                    "destination": "https://reservoir-ghandoffs-projects.vercel.app/reservoir/:path*"
                    }
        ]
}
