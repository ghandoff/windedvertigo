{
        "outputDirectory": ".",
        "ignoreCommand": "npx turbo-ignore @windedvertigo/site",
        "headers": [
                    {
                                    "source": "/(.*)",
                                    "headers": [
                                                    { "key": "X-Content-Type-Options", "value": "nosniff" },
                                                    { "key": "X-Frame-Options", "value": "DENY" },
                                                    { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                                                    { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
                                                { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
                                                    {
                                                                    "key": "Strict-Transport-Security",
                                                                    "value": "max-age=63072000; includeSubDomains; preload"
                                                    },
                                                    {
                                                                    "key": "Content-Security-Policy",
                                                                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self'; frame-src 'none'; base-uri 'self'; form-action 'self'"
                                                    }
                                    ]
                    }
        ],
        "redirects": [
                    {
                                    "source": "/vertigo-vault/:path*",
                                    "destination": "/harbor/vertigo-vault/:path*",
                                    "permanent": true
                    },
                    {
                                    "source": "/vertigo-vault",
                                    "destination": "/harbor/vertigo-vault",
                                    "permanent": true
                    }
        ],
        "rewrites": [
                    {
                                    "source": "/harbor/creaseworks",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/harbor/creaseworks"
                    },
                    {
                                    "source": "/harbor/creaseworks/",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/harbor/creaseworks"
                    },
                    {
                                    "source": "/harbor/creaseworks/:path*",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/harbor/creaseworks/:path*"
                    },
                    {
                                    "source": "/harbor/vertigo-vault",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/harbor/vertigo-vault"
                    },
                    {
                                    "source": "/harbor/vertigo-vault/",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/harbor/vertigo-vault"
                    },
                    {
                                    "source": "/harbor/vertigo-vault/:path*",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/harbor/vertigo-vault/:path*"
                    },
                    {
                                    "source": "/harbor/deep-deck",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/harbor/deep-deck"
                    },
                    {
                                    "source": "/harbor/deep-deck/",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/harbor/deep-deck"
                    },
                    {
                                    "source": "/harbor/deep-deck/:path*",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/harbor/deep-deck/:path*"
                    },
                    {
                                    "source": "/harbor/admin/login",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/harbor/creaseworks/login?callbackUrl=%2Fadmin"
                    },
                    {
                                    "source": "/harbor/admin",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/harbor/creaseworks/admin"
                    },
                    {
                                    "source": "/harbor/admin/:path*",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/harbor/creaseworks/admin/:path*"
                    },
                    {
                                    "source": "/harbor",
                                    "destination": "https://harbor-ghandoffs-projects.vercel.app/harbor"
                    },
                    {
                                    "source": "/harbor/",
                                    "destination": "https://harbor-ghandoffs-projects.vercel.app/harbor"
                    },
                    {
                                    "source": "/harbor/:path*",
                                    "destination": "https://harbor-ghandoffs-projects.vercel.app/harbor/:path*"
                    }
        ]
}
