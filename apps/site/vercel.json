{
        "outputDirectory": ".",
        "ignoreCommand": "npx turbo-ignore @windedvertigo/site",
        "headers": [
                    {
                                    "source": "/(.*)",
                                    "headers": [
                                                    { "key": "X-Content-Type-Options", "value": "nosniff" },
                                                    { "key": "X-Frame-Options", "value": "DENY" },
                                                    { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                                                    { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
                                                { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
                                                    {
                                                                    "key": "Strict-Transport-Security",
                                                                    "value": "max-age=63072000; includeSubDomains; preload"
                                                    },
                                                    {
                                                                    "key": "Content-Security-Policy",
                                                                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self'; frame-src 'none'; base-uri 'self'; form-action 'self'"
                                                    }
                                    ]
                    }
        ],
        "redirects": [],
        "rewrites": [
                    {
                                    "source": "/reservoir/creaseworks",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks"
                    },
                    {
                                    "source": "/reservoir/creaseworks/",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks"
                    },
                    {
                                    "source": "/reservoir/creaseworks/:path*",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks/:path*"
                    },
                    {
                                    "source": "/reservoir/vertigo-vault",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/reservoir/vertigo-vault"
                    },
                    {
                                    "source": "/reservoir/vertigo-vault/",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/reservoir/vertigo-vault"
                    },
                    {
                                    "source": "/reservoir/vertigo-vault/:path*",
                                    "destination": "https://vertigo-vault-ghandoffs-projects.vercel.app/reservoir/vertigo-vault/:path*"
                    },
                    {
                                    "source": "/reservoir/deep-deck",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/reservoir/deep-deck"
                    },
                    {
                                    "source": "/reservoir/deep-deck/",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/reservoir/deep-deck"
                    },
                    {
                                    "source": "/reservoir/deep-deck/:path*",
                                    "destination": "https://deep-deck-ghandoffs-projects.vercel.app/reservoir/deep-deck/:path*"
                    },
                    {
                                    "source": "/reservoir/admin/login",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks/login"
                    },
                    {
                                    "source": "/reservoir/admin",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks/admin"
                    },
                    {
                                    "source": "/reservoir/admin/:path*",
                                    "destination": "https://creaseworks-ghandoffs-projects.vercel.app/reservoir/creaseworks/admin/:path*"
                    },
                    {
                                    "source": "/reservoir",
                                    "destination": "https://reservoir-ghandoffs-projects.vercel.app/reservoir"
                    },
                    {
                                    "source": "/reservoir/",
                                    "destination": "https://reservoir-ghandoffs-projects.vercel.app/reservoir"
                    },
                    {
                                    "source": "/reservoir/:path*",
                                    "destination": "https://reservoir-ghandoffs-projects.vercel.app/reservoir/:path*"
                    }
        ]
}
