{
  "name": "windedvertigo-site",
  "private": true,
  "workspaces": [
    "site",
    "port",
    "ops",
    "ancestry",
    "port-jobs",
    "packages/*",
    "apps/harbour/packages/security",
    "apps/harbour/values-auction",
    "apps/nordic-sqr-rct"
  ],
  "scripts": {
    "sync:footer": "node scripts/sync-footer.mjs",
    "dev:values-auction": "npm run dev -w apps/harbour/values-auction",
    "build:values-auction": "npm run build -w apps/harbour/values-auction",
    "deploy:values-auction": "npm run deploy:spa -w apps/harbour/values-auction",
    "dev:harbour": "npm run dev -w harbour",
    "build:harbour": "npm run build -w harbour",
    "dev:port": "npm run dev -w port",
    "build:port": "npm run build -w port",
    "deploy:port": "bash scripts/deploy-port.sh",
    "deploy:port:preview": "bash scripts/deploy-port.sh --preview",
    "dev:ops": "npm run dev -w ops",
    "build:ops": "npm run build -w ops",
    "deploy:ops": "bash scripts/deploy-ops.sh",
    "deploy:ops:preview": "bash scripts/deploy-ops.sh --preview",
    "dev:ancestry": "npm run dev -w @windedvertigo/ancestry",
    "build:ancestry": "npm run build -w @windedvertigo/ancestry",
    "deploy:ancestry": "bash scripts/deploy-ancestry.sh",
    "deploy:ancestry:preview": "bash scripts/deploy-ancestry.sh --preview",
    "deploy:nordic": "bash scripts/deploy-nordic.sh",
    "deploy:nordic:preview": "bash scripts/deploy-nordic.sh --preview",
    "deploy:site": "bash scripts/deploy-site.sh",
    "deploy:site:preview": "bash scripts/deploy-site.sh --preview"
  },
  "dependencies": {
    "@notionhq/client": "^5.19.0"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "marked": "^18.0.2",
    "typescript": "^6.0.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4"
  }
}
