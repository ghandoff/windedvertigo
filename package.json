{
  "name": "windedvertigo-site",
  "private": true,
  "workspaces": [
    "harbour",
    "crm",
    "ops",
    "tidal-pool",
    "packages/*"
  ],
  "scripts": {
    "sync:footer": "node scripts/sync-footer.mjs",
    "dev:harbour": "npm run dev -w harbour",
    "build:harbour": "npm run build -w harbour",
    "dev:crm": "npm run dev -w crm",
    "build:crm": "npm run build -w crm",
    "deploy:crm": "bash scripts/deploy-crm.sh",
    "deploy:crm:preview": "bash scripts/deploy-crm.sh --preview",
    "dev:ops": "npm run dev -w ops",
    "build:ops": "npm run build -w ops",
    "deploy:ops": "bash scripts/deploy-ops.sh",
    "deploy:ops:preview": "bash scripts/deploy-ops.sh --preview",
    "dev:tidal-pool": "npm run dev -w tidal-pool",
    "build:tidal-pool": "npm run build -w tidal-pool"
  },
  "dependencies": {
    "@notionhq/client": "^5.14.0"
  },
  "engines": {
    "node": ">=22"
  }
}
